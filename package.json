{
  "name": "promptfoo-custom-gpt-tools",
  "version": "0.2.0",
  "description": "Promptfoo provider and assertions for evaluating Custom GPT workflows that process files with Code Interpreter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pm990320/promptfoo-custom-gpt-tools.git"
  },
  "homepage": "https://github.com/pm990320/promptfoo-custom-gpt-tools#readme",
  "bugs": {
    "url": "https://github.com/pm990320/promptfoo-custom-gpt-tools/issues"
  },
  "author": "pm990320",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./assertions": {
      "types": "./dist/assertions/index.d.ts",
      "import": "./dist/assertions/index.js",
      "require": "./dist/assertions/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ assertions/",
    "lint:fix": "eslint --fix src/ assertions/",
    "check": "npm run typecheck && npm run lint",
    "prepare": "npm run build"
  },
  "keywords": [
    "promptfoo",
    "openai",
    "code-interpreter",
    "custom-gpt",
    "excel",
    "evaluation"
  ],
  "dependencies": {
    "exceljs": "^4.4.0",
    "mime-types": "^2.1.35",
    "openai": "^4.104.0"
  },
  "peerDependencies": {
    "promptfoo": ">=0.100.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.29",
    "eslint": "^10.0.2",
    "promptfoo": "^0.111.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1"
  }
}
